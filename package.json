{
  "name": "agendum",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "daemon": "bun run src/daemon/index.ts",
    "dev:web": "bun run --cwd web dev",
    "build:web": "bun run --cwd web build",
    "typecheck": "bunx tsc --noEmit",
    "audit:private": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/audit-private-data.ps1",
    "package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-windows-installer.ps1"
  },
  "dependencies": {
    "cron-parser": "^4.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.4.0"
  }
}
